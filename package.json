{
  "name": "@hongmaple0820/scale-engine",
  "version": "0.7.0",
  "description": "SCALE Engine v0.7.0 — AI engineering scaffold: 11 agent adapters, 8 subagents, 10 skills, 10 MCP configs, layered rules, plugin market, dashboard GUI, FSM workflows, guardrails, self-evolution",
  "type": "module",
  "bin": {
    "scale": "./dist/api/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/api/cli.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "mcp": "node dist/api/mcp.js",
    "serve": "node dist/api/http.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "citty": "^0.1.6",
    "drizzle-orm": "^0.32.2",
    "execa": "^9.3.0",
    "hono": "^4.5.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
